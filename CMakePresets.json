{
    "version": 2,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20
    },
    "configurePresets": [
        {
            "name": "regular",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/artifacts",
                "CMAKE_EXPORT_COMPILE_COMMANDS": true,
                "DEV_BRANCH": "OFF",
                "NEW_DYNAREC": "OFF",
                "QT": "ON"
            },
            "generator": "Ninja Multi-Config"
        },
        {
            "name": "regular-ndr",
            "cacheVariables": {
                "NEW_DYNAREC": "ON"
            },
            "inherits": "regular"
        },
        {
            "name": "development",
            "cacheVariables": {
                "DEV_BRANCH": "ON"
            },
            "inherits": "regular"
        },
        {
            "name": "development-ndr",
            "cacheVariables": {
                "DEV_BRANCH": "ON"
            },
            "inherits": "regular-ndr"
        },
        {
            "name": "regular-sdl",
            "cacheVariables": {
                "QT": "OFF"
            },
            "inherits": "regular"
        },
        {
            "name": "regular-ndr-sdl",
            "cacheVariables": {
                "QT": "OFF"
            },
            "inherits": "regular-ndr"
        },
        {
            "name": "development-sdl",
            "cacheVariables": {
                "QT": "OFF"
            },
            "inherits": "development"
        },
        {
            "name": "development-ndr-sdl",
            "cacheVariables": {
                "QT": "OFF"
            },
            "inherits": "development-ndr"
        }
    ],
    "buildPresets": [
        {
            "name": "release",
            "configurePreset": "regular",
            "configuration": "Release"
        },
        {
            "name": "debug",
            "configurePreset": "regular",
            "configuration": "Debug"
        },
        {
            "name": "ultradebug",
            "configurePreset": "regular",
            "configuration": "UltraDebug"
        },
        {
            "name": "optimized",
            "configurePreset": "regular",
            "configuration": "Optimized"
        }
    ],
    "testPresets": []
}
